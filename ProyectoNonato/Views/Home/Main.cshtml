    For more information on enabling MVC for empty projects, visit https://go.microsoft.com/fwlink/?LinkID=397860
*@
@{
}
@{
    ViewData["Title"] = "Panel Principal";
}

<div class="text-center mt-5">
    <h1 class="display-4">Bienvenido, @User.Identity.Name</h1>
    <p class="lead">Selecciona una de las secciones a las que tienes acceso.</p>
</div>

<div class="row mt-4 justify-content-center">

    <!-- Visible para Admin -->
    @if (User.IsInRole("Admin"))
    {
        <div class="col-md-4 mb-3">
            <div class="card shadow-sm">
                <div class="card-body text-center">
                    <h5 class="card-title">Alumnos</h5>
                    <p class="card-text">Gestión total de los alumnos del sistema.</p>
                    <a asp-controller="Alumnos" asp-action="Index" class="btn btn-primary">Ir a Alumnos</a>
                </div>
            </div>
        </div>
    }

    <!-- Visible para Admin y Consultor -->
    @if (User.IsInRole("Admin") || User.IsInRole("Consultor"))
    {
        <div class="col-md-4 mb-3">
            <div class="card shadow-sm">
                <div class="card-body text-center">
                    <h5 class="card-title">Grupos</h5>
                    <p class="card-text">Consulta y gestión de grupos.</p>
                    <a asp-controller="Grupos" asp-action="Index" class="btn btn-success">Ir a Grupos</a>
                </div>
            </div>
        </div>
    }

    <!-- Visible para Admin y Gestor -->
    @if (User.IsInRole("Admin") || User.IsInRole("Gestor"))
    {
        <div class="col-md-4 mb-3">
            <div class="card shadow-sm">
                <div class="card-body text-center">
                    <h5 class="card-title">Profesores</h5>
                    <p class="card-text">Consulta y gestión de profesores.</p>
                    <a asp-controller="Profesores" asp-action="Index" class="btn btn-warning">Ir a Profesores</a>
                </div>
            </div>
        </div>
    }

    <!-- Secciones Adicionales Visibles para Admin -->
    @if (User.IsInRole("Admin"))
    {
        <div class="col-md-4 mb-3">
            <div class="card shadow-sm">
                <div class="card-body text-center">
                    <h5 class="card-title">Materias</h5>
                    <p class="card-text">Gestión de materias.</p>
                    <a asp-controller="Materias" asp-action="Index" class="btn btn-info text-white">Ir a Materias</a>
                </div>
            </div>
        </div>

        <div class="col-md-4 mb-3">
            <div class="card shadow-sm">
                <div class="card-body text-center">
                    <h5 class="card-title">Tutores</h5>
                    <p class="card-text">Gestión de tutores asignados.</p>
                    <a asp-controller="Tutores" asp-action="Index" class="btn btn-info text-white">Ir a Tutores</a>
                </div>
            </div>
        </div>

        <div class="col-md-4 mb-3">
            <div class="card shadow-sm">
                <div class="card-body text-center">
                    <h5 class="card-title">Inscripciones</h5>
                    <p class="card-text">Gestión de inscripciones a grupos.</p>
                    <a asp-controller="Inscripciones" asp-action="Index" class="btn btn-info text-white">Ir a Inscripciones</a>
                </div>
            </div>
        </div>

        <div class="col-md-4 mb-3">
            <div class="card shadow-sm">
                <div class="card-body text-center">
                    <h5 class="card-title">Horarios</h5>
                    <p class="card-text">Gestión de horarios de clases.</p>
                    <a asp-controller="Horarios" asp-action="Index" class="btn btn-info text-white">Ir a Horarios</a>
                </div>
            </div>
        </div>

        <div class="col-md-4 mb-3">
            <div class="card shadow-sm">
                <div class="card-body text-center">
                    <h5 class="card-title">Boletas</h5>
                    <p class="card-text">Gestión de boletas de calificaciones.</p>
                    <a asp-controller="Boletas" asp-action="Index" class="btn btn-info text-white">Ir a Boletas</a>
                </div>
            </div>
        </div>

        <div class="col-md-4 mb-3">
            <div class="card shadow-sm">
                <div class="card-body text-center">
                    <h5 class="card-title">Detalle Boleta</h5>
                    <p class="card-text">Gestión de detalles de cada boleta.</p>
                    <a asp-controller="DetalleBoleta" asp-action="Index" class="btn btn-info text-white">Ir a Detalle</a>
                </div>
            </div>
        </div>
    }

</div>
